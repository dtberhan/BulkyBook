@using BulkyBook.Models
@model List<Product>

<div class="card shadow border-1 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Product List</h2>
            </div>
        </div>
    </div>
       

    <div class="card-body p-4">
    <div class="row pb-3">
        <div class="col-6">

        </div>
        <div class="col-6 text-end">
            <a asp-controller="Product" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create New Product
            </a>
        </div>
    </div>
        <table class="table table-bordered table-striped">
            <thead>
                <tr class="text-center">
                    <th>Title</th>
                    <th>ISBN</th>
                    <th>Price</th>
                    <th>Author</th>
                    <th>Category</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.OrderBy(x => x.Title))
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.ISBN</td>
                        <td>@item.Price</td>
                        <td>@item.Author</td>
                        <td></td>
                        <td>
                            <div class="w-75 btn-group" role="group">

                                <a asp-controller="Product" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary mx-2 align-items-center" style="background-color:dodgerblue">
                                    <i class="bi bi-pencil-square"></i> Edit
                                </a>
                                <a asp-controller="Product" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger mx-2 align-items-center">
                                    <i class="bi bi-trash"></i> Delete
                                </a>

                            </div>
                        </td>
                    </tr>
                }
        </table>
       <div class="row col-12">
           
            <div class="col-3">
            
            
                <a asp-area = "Customer" asp-controller="Home" asp-action="Index" class="btn btn-primary bg-success w-50 me-0 text-bg-success form-control h" >
                    <i class="bi bi-skip-backward"></i> Back to List
                </a>
            </div>
       </div>
        @section Scripts{
            @{
                <partial name="_ValidationScriptsPartial" />
            }
        }
    </div>
</div>
