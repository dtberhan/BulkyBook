@using BulkyBook.Models
@model Product

<div class="card shadow border-1 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-2">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Delete Product</h2>
            </div>
        </div>
    </div>

    <div class="card-body p-4">
        <form method="post" class="row">
            <div class="border p-3">

              
                <input asp-for="Id" class="form-control border-0 shadow" hidden />
                <div class="form-floating py-2 col-12">
                    <input asp-for="Title" class="form-control border-0 shadow" disabled/>
                    <label asp-for="Title" class="ms-2"></label>

                 
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Description" class="form-control border-0 shadow" disabled />
                    <label asp-for="Description" class="ms-2"></label>
                  
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="ISBN" class="form-control border-0 shadow" disabled />
                    <label asp-for="ISBN" class="ms-2"></label>

               
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Author" class="form-control border-0 shadow" disabled />
                    <label asp-for="Author" class="ms-2"></label>
                    
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="ListPrice" class="form-control border-0 shadow" disabled />
                    <label asp-for="ListPrice" class="ms-2"></label>

                    
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Price" class="form-control border-0 shadow" disabled />
                    <label asp-for="Price" class="ms-2"></label>
                    
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Price50" class="form-control border-0 shadow" disabled/>
                    <label asp-for="Price50" class="ms-2"></label>

                    
                </div>
                <div class="form-floating py-2 col-12">
                    <input asp-for="Price100" class="form-control border-0 shadow" disabled/>
                    <label asp-for="Price100" class="ms-2"></label>
                    
                </div>
                <div class="row m-3">
                    <div class="col-6 col-md-3">
                        <button type="submit" class="btn btn-primary form-control">Delete</button>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-controller="Product" asp-action="Index" class="btn btn-outline-primary border form-control h">
                            <i class="bi bi-skip-backward-fill"></i> Back to List
                        </a>
                    </div>

                </div>


            </div>
        </form>

        @section Scripts{
            @{
                <partial name="_ValidationScriptsPartial" />
            }
        }
    </div>
</div>

